{
  "name": "pitch",
  "version": "1.1.5",
  "private": true,
  "homepage": "http://adamgolota.github.io/pitch",
  "dependencies": {
    "react": "^16.8.0",
    "react-dom": "^16.8.0",
    "react-ga": "^2.7.0",
    "react-scripts": "3.4.1",
    "styled-components": "^5.0.0"
  },
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "start": "export NODE_OPTIONS=--openssl-legacy-provider && react-scripts start",
    "build": "node update-build.js && export NODE_OPTIONS=--openssl-legacy-provider && react-scripts build",
    "test": "export NODE_OPTIONS=--openssl-legacy-provider && react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
